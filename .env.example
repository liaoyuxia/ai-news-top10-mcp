FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# Optional. Fill this only if the Feishu bot enabled signature verification.
FEISHU_SECRET=

# Optional news ranking controls.
NEWS_LIMIT=10
NEWS_HOURS_BACK=24
NEWS_LANGUAGE=mixed
NEWS_CANDIDATE_LIMIT=50
NEWS_MAX_PER_HOST=2
NEWS_VERIFY_ARTICLE_DATES=true
NEWS_TRANSLATE_ENGLISH_TITLES=true
NEWS_TRANSLATION_PROVIDERS=baidu,google,mymemory
NEWS_INCLUDE_GOOGLE_NEWS=true
NEWS_INCLUDE_FAILED_FEEDS=false

# Optional. Recommended for servers that cannot access Google Translate.
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_SECRET=
